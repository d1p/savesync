# SaveSync-Bridge — S3 credentials for rclone
# Copy this to .env and fill in your values.
# These are passed as environment variables to rclone.

RCLONE_CONFIG_S3_TYPE=s3
RCLONE_CONFIG_S3_PROVIDER=AWS
RCLONE_CONFIG_S3_ACCESS_KEY_ID=your_access_key_here
RCLONE_CONFIG_S3_SECRET_ACCESS_KEY=your_secret_key_here
RCLONE_CONFIG_S3_REGION=us-east-1
# For Cloudflare R2, MinIO, or other S3-compatible:
# RCLONE_CONFIG_S3_ENDPOINT=https://your-endpoint.example.com
