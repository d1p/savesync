# SaveSync-Bridge — S3 credentials for rclone
# Copy this to .env and fill in your values.
# These are passed as environment variables to rclone.

# Optional Google Drive OAuth client overrides for the Backups UI.
# Leave these unset to use rclone's default client.
RCLONE_DRIVE_CLIENT_ID=your-google-client-id
RCLONE_DRIVE_CLIENT_SECRET=your-google-client-secret
# RCLONE_DRIVE_SCOPE=drive
# For Cloudflare R2, MinIO, or other S3-compatible:
# RCLONE_CONFIG_S3_ENDPOINT=https://your-endpoint.example.com
